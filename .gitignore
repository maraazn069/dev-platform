# ================================================================
# .gitignore — File yang TIDAK diupload ke GitHub
# ================================================================

# --- WAJIB: Jangan pernah commit file ini! ---
.env
server/data/users.json

# Node modules (diinstall ulang via npm install)
node_modules/

# Data runtime (dibuat otomatis di VPS)
server/data/*.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
*.swp
*.swo
*~

# Logs
*.log
logs/
npm-debug.log*

# Build output
dist/
build/
