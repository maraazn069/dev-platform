FROM node:20-alpine

# Install docker CLI agar portal bisa exec command ke container lain (mysql, postgres, nginx)
RUN apk add --no-cache docker-cli openssl

WORKDIR /app

COPY package*.json ./
RUN npm install --production

COPY server/ ./server/
COPY public/ ./public/

RUN mkdir -p /app/server/data

EXPOSE 3000

CMD ["node", "server/index.js"]
