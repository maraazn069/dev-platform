# ================================================================
# .env.example — Semua konfigurasi Self-Hosted Dev Platform
# Salin ke .env:  cp .env.example .env
# JANGAN commit .env ke GitHub! Sudah di-exclude oleh .gitignore
# ================================================================

# ----------------------------------------------------------------
# DOMAIN & SSL
# ----------------------------------------------------------------

# Domain utama platform kamu (tanpa https://)
# Contoh: dev.domainku.com
DOMAIN=dev.domainmu.com

# Email untuk mendapatkan sertifikat HTTPS gratis dari Let's Encrypt
# Wajib diisi! Let's Encrypt kirim notif renewal ke email ini
LETSENCRYPT_EMAIL=emailkamu@gmail.com

# Protocol: http (default) atau https (setelah jalankan setup-https.sh)
PROTOCOL=http

# ----------------------------------------------------------------
# KEAMANAN SESSION
# ----------------------------------------------------------------

# Secret key untuk enkripsi session login portal
# Ganti dengan string acak panjang minimal 32 karakter
# Generate: openssl rand -base64 32
SESSION_SECRET=ganti-dengan-string-acak-sangat-panjang-sekali-wajib-diganti

# ----------------------------------------------------------------
# TIMEZONE
# ----------------------------------------------------------------

# Zona waktu server
# Opsi Indonesia: Asia/Jakarta | Asia/Makassar | Asia/Jayapura
TZ=Asia/Jakarta

# ----------------------------------------------------------------
# DATABASE POSTGRESQL
# ----------------------------------------------------------------

# Password untuk user postgres (superuser PostgreSQL)
# Dipakai saat koneksi dari tools eksternal (DBeaver, pgAdmin, dll)
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=gantiPasswordPostgresKuat123456

# ----------------------------------------------------------------
# DATABASE MYSQL
# ----------------------------------------------------------------

# Password root MySQL (akses penuh ke semua database)
# Generate: openssl rand -base64 24
MYSQL_ROOT_PASSWORD=gantiPasswordRootMySQL456789

# Password untuk user 'admin' MySQL (akses terbatas)
# Generate: openssl rand -base64 20
MYSQL_PASSWORD=gantiPasswordMySQLAdmin789012

# ----------------------------------------------------------------
# CLOUDFLARE TUNNEL (untuk akses database dari luar VPS)
# ----------------------------------------------------------------

# Cloudflare Tunnel memungkinkan kamu akses PostgreSQL/MySQL
# dari laptop pakai DBeaver, TablePlus, MySQL Workbench, dsb.
# tanpa membuka port database ke internet.
#
# Cara setup:
#   1. Buka: https://one.dash.cloudflare.com
#   2. Buat Tunnel baru → copy token-nya
#   3. Tempel token di bawah
CLOUDFLARE_TUNNEL_TOKEN=

# ----------------------------------------------------------------
# DIREKTORI DATA
# ----------------------------------------------------------------

# Tempat menyimpan file/project semua user di VPS
# Biarkan default kecuali kamu punya alasan khusus
DATA_DIR=/opt/devplatform/data

# ================================================================
# INFORMASI KONEKSI DATABASE (referensi, tidak perlu diubah)
# ================================================================
#
# PostgreSQL dari dalam VPS (terminal / code-server):
#   Host    : devplatform-postgres   (nama container)
#   Port    : 5432
#   Database: devplatform
#   User    : namauser (tiap user punya schema sendiri)
#
# MySQL dari dalam VPS (terminal / code-server):
#   Host    : devplatform-mysql      (nama container)
#   Port    : 3306
#   Database: db_namauser
#   User    : namauser
#
# Akses dari laptop via Cloudflare Tunnel:
#   Host    : db.dev.domainmu.com
#   Port    : 5432 (PG) / 3306 (MySQL)
#
# Adminer (Web UI database):
#   URL     : https://db-admin.dev.domainmu.com
# ================================================================
