# ================================================================
# .env.example — Konfigurasi Self-Hosted Dev Platform
# Salin ke .env:  cp .env.example .env
# JANGAN commit .env ke GitHub! Sudah di-exclude oleh .gitignore
# ================================================================

# ----------------------------------------------------------------
# DOMAIN & SSL
# ----------------------------------------------------------------

# Domain utama platform (tanpa https://). Wildcard *.dev.domain juga dipakai
# untuk subdomain code-server per user (user1.dev.domain, dll).
DOMAIN=dev.domainmu.com

# Email untuk Let's Encrypt notification renewal
LETSENCRYPT_EMAIL=emailkamu@gmail.com

# Protocol: http (default) atau https (setelah jalankan setup-https.sh)
PROTOCOL=http

# ----------------------------------------------------------------
# KEAMANAN SESSION & PORTAL
# ----------------------------------------------------------------

# Session secret — generate ulang dengan: openssl rand -base64 32
SESSION_SECRET=ganti-dengan-string-acak-sangat-panjang-sekali-wajib-diganti

# Idle timeout dalam menit. Setelah X menit tanpa aktivitas, user otomatis logout.
# Default 60. Set 30 untuk lebih ketat, 240 untuk longgar.
IDLE_TIMEOUT_MIN=60

# ----------------------------------------------------------------
# RESOURCE LIMITS PER USER (code-server container)
# ----------------------------------------------------------------
# Penting biar 1 user tidak bisa OOM/CPU-starve seluruh VPS.
# Untuk VPS 4 vCPU + 8GB RAM dengan ~5 user aktif, default cukup.
# Untuk VPS lebih besar, naikkan CODE_SERVER_MEM jadi 4g.

CODE_SERVER_MEM=2g
CODE_SERVER_CPUS=1.5
CODE_SERVER_PIDS=300

# ----------------------------------------------------------------
# AKSES REMOTE DATABASE (whitelist IP)
# ----------------------------------------------------------------
# Daftar IP yang BOLEH konek ke MySQL (3306) & PostgreSQL (5432) dari luar VPS.
# Format: koma, spasi, atau CIDR. Kosongkan untuk allow semua (TIDAK DIREKOMENDASIKAN).
# Contoh: DB_REMOTE_IPS=203.0.113.5,198.51.100.10/32
# Untuk mengetahui IP publik kamu: curl ifconfig.me
DB_REMOTE_IPS=

# ----------------------------------------------------------------
# TIMEZONE
# ----------------------------------------------------------------

# Asia/Jakarta | Asia/Makassar | Asia/Jayapura
TZ=Asia/Jakarta

# ----------------------------------------------------------------
# DATABASE PASSWORDS
# ----------------------------------------------------------------

# Generate semua dengan: openssl rand -base64 24

POSTGRES_PASSWORD=gantiPasswordPostgresKuat123456
MYSQL_ROOT_PASSWORD=gantiPasswordRootMySQL456789
MYSQL_PASSWORD=gantiPasswordMySQLAdmin789012

# ----------------------------------------------------------------
# pgAdmin Web UI
# ----------------------------------------------------------------

PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=gantiAdminKuat321

# ----------------------------------------------------------------
# DIREKTORI DATA & BACKUP
# ----------------------------------------------------------------

DATA_DIR=/opt/devplatform/data
BACKUP_ROOT=/opt/devplatform/backups

# ----------------------------------------------------------------
# CLOUDFLARE R2 BACKUP (opsional — untuk disaster recovery)
# Buat token di Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ----------------------------------------------------------------

R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=devplatform-backups

# ================================================================
# REFERENSI KONEKSI DATABASE (tidak perlu diubah)
# ================================================================
#
# Internal (dari code-server / container):
#   PG    : devplatform-postgres:5432
#   MySQL : devplatform-mysql:3306
#
# External (dari laptop, lewat IP/domain VPS):
#   PG    : DOMAIN:5432 (atau IP VPS:5432)
#   MySQL : DOMAIN:3306 (atau IP VPS:3306)
#   Hanya IP yang ada di DB_REMOTE_IPS yang bisa konek.
#
# Web UI:
#   phpMyAdmin : https://mysql.DOMAIN
#   pgAdmin    : https://pgadmin.DOMAIN
#   Portal     : https://DOMAIN
# ================================================================
