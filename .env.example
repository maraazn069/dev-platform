# ============================================================
# Self-Hosted Dev Platform — Konfigurasi Environment
# Salin ke .env: cp .env.example .env
# ============================================================

# Domain utama VPS (tanpa http/https)
DOMAIN=dev.domainmu.com

# Email untuk Let's Encrypt HTTPS gratis
LETSENCRYPT_EMAIL=email@kamu.com

# Secret untuk session portal (ganti dengan string acak panjang)
SESSION_SECRET=ganti-dengan-string-acak-sangat-panjang-123456

# Timezone
TZ=Asia/Jakarta

# ---- Database PostgreSQL ----
POSTGRES_PASSWORD=gantiPasswordPostgresKuat123

# ---- Database MySQL ----
MYSQL_ROOT_PASSWORD=gantiRootPasswordMySQL456
MYSQL_PASSWORD=gantiPasswordMySQLAdmin789

# ---- Cloudflare (untuk akses database eksternal) ----
# Tunnel token didapat dari: https://one.dash.cloudflare.com
# Setelah buat tunnel, isi token di bawah
CLOUDFLARE_TUNNEL_TOKEN=

# ---- Folder data ----
DATA_DIR=/opt/devplatform/data
