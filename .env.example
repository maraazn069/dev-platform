# ============================================================
# Self-Hosted Dev Platform — Konfigurasi Environment
# Salin file ini ke .env lalu isi nilainya
# cp .env.example .env
# ============================================================

# Domain utama VPS kamu (tanpa http/https)
# Contoh: dev.domainku.com
DOMAIN=dev.domainku.com

# Email untuk Let's Encrypt (sertifikat HTTPS gratis)
LETSENCRYPT_EMAIL=email@kamu.com

# Password untuk akses code-server (VS Code di browser)
# Ganti dengan password yang kuat!
PASSWORD=gantiDenganPasswordKuat123

# Timezone VPS
TZ=Asia/Jakarta

# Port internal code-server (jangan diubah kecuali ada konflik)
CODE_SERVER_PORT=8080

# Folder tempat project/file user disimpan di VPS
DATA_DIR=/opt/devplatform/data

# Jumlah max user bersamaan (sesuaikan dengan RAM VPS)
# 4 vCPU / 56 GB RAM bisa handle 1-10 user dengan nyaman
MAX_USERS=10
